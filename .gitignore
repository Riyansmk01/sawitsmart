# CodeIgniter 4 .gitignore — Vercel Deploy

# Environment & secrets (JANGAN commit .env!)
.env
*.env.local
*.env.*.local

# ── VERCEL DEPLOY NOTE ──────────────────────────────────────────────────────
# vendor/ dan system/ HARUS di-push ke GitHub agar Vercel bisa menjalankan CI4
# (Vercel tidak menjalankan 'composer install' saat build)
# Jika tidak deploy ke Vercel, bisa uncomment baris vendor/ dan system/ di bawah
# ────────────────────────────────────────────────────────────────────────────

# vendor/   <- AKTIFKAN jika tidak pakai Vercel
# system/   <- AKTIFKAN jika tidak pakai Vercel

# Writable directories (logs, cache, session, uploads)
writable/cache/*
writable/debugbar/*
writable/logs/*
writable/session/*
writable/tmp/*
writable/uploads/*
!writable/cache/.gitkeep
!writable/debugbar/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep
!writable/tmp/.gitkeep
!writable/uploads/.gitkeep

# Public writable (session files lokal)
public/writable/

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.phpstorm.meta.php
_ide_helper.php
_ide_helper_models.php

# PHPUnit
.phpunit.result.cache
build/

# Temp / Backup
*.bak
*.swp
*.tmp
*~

# Public uploads
public/uploads/*
!public/uploads/.gitkeep
