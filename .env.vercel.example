#--------------------------------------------------------------------
# ENVIRONMENT PRODUCTION — Template untuk Vercel
# Copy file ini ke .env dan isi nilai yang sesuai
# JANGAN commit .env ke GitHub!
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://YOUR-PROJECT.vercel.app/'
app.forceGlobalSecureRequests = false
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE (gunakan database online, bukan localhost!)
# Rekomendasi: Railway, Aiven, PlanetScale, Supabase, Neon
#--------------------------------------------------------------------

database.default.hostname = YOUR_DB_HOST
database.default.database = YOUR_DB_NAME
database.default.username = YOUR_DB_USER
database.default.password = YOUR_DB_PASSWORD
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESSION — gunakan database driver di production
#--------------------------------------------------------------------

session.driver = CodeIgniter\Session\Handlers\DatabaseHandler
session.cookieName = ci_session
session.expiration = 7200
session.savePath = ci_sessions
session.matchIP = false

#--------------------------------------------------------------------
# KLIKQRIS PAYMENT GATEWAY
#--------------------------------------------------------------------

KLIKQRIS_API_KEY      = QDHKVXNSOHPdJbKWACwFieYWXsHH8Vmhdr2SKQXP
KLIKQRIS_MERCHANT_ID  = 177929799620
KLIKQRIS_BASE_URL     = https://klikqris.com/api/qrisv2
KLIKQRIS_WEBHOOK_URL  = https://YOUR-PROJECT.vercel.app/payment/webhook

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

logger.threshold = 1
